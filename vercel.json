{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/(.*\\.pdf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/digital-recoil", "destination": "/digital-recoil.html" },
    { "source": "/white-papers/digital-recoil", "destination": "/digital-recoil.html" },
    { "source": "/white-papers", "destination": "/index.html" }
  ]
}
